# cli-bad: health — non-compliant implementation
# Mixed stdout/stderr, unstructured error, exit 1

SUBCOMMAND="${1:-}"

case "$SUBCOMMAND" in
  check)
    printf "WARN: cache stale (last updated 4h ago)\n" >&2
    printf "INFO: checking services...\n"
    printf "INFO: api-server ... ok\n"
    printf "INFO: database ... ok\n"
    printf "\033[1;31mERROR: registry auth failed: token expired 2h ago\033[0m\n" >&2
    printf "INFO: 3 services checked, 1 failed\n"
    exit 1
    ;;
  *)
    echo "Usage: health <check>" >&2
    exit 1
    ;;
esac
