#!/usr/bin/env bash
# cli-good: deploy — spec-compliant implementation
# Typed exit codes, retryable hint, retry_after_ms, idempotency key

STATE_FILE="/tmp/cli_good_deploy_state"

VERSION="" ENV="" IDEMPOTENCY_KEY=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --version)         VERSION="$2";          shift 2 ;;
    --env)             ENV="$2";              shift 2 ;;
    --idempotency-key) IDEMPOTENCY_KEY="$2";  shift 2 ;;
    --output|--timeout) shift 2 ;;
    *)                 shift ;;
  esac
done

# First call: conflict with retry hint. Second call: success.
if [ ! -f "$STATE_FILE" ]; then
  touch "$STATE_FILE"
  printf '{"ok":false,"data":null,"error":{"code":"CONFLICT","message":"Another deployment is in progress","retryable":true,"retry_after_ms":2000,"side_effects":"none"},"warnings":[],"meta":{"duration_ms":5,"schema_version":"1.0"}}\n'
  exit 7
else
  rm -f "$STATE_FILE"
  printf '{"ok":true,"data":{"status":"deployed","version":"%s","env":"%s","deploy_id":"deploy-new-001"},"error":null,"warnings":[],"meta":{"duration_ms":340,"schema_version":"1.0"}}\n' "$VERSION" "$ENV"
fi
